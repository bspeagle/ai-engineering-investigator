# API Configuration
OPENAI_API_KEY=your_openai_api_key_here
GITLAB_TOKEN=your_gitlab_personal_access_token_here
GITLAB_WEBHOOK_SECRET=generate_random_secret_token_here

# GitLab Configuration
GITLAB_URL=https://gitlab.com
GITLAB_PROJECT_ID=your_project_id_here

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# OpenAI Model Configuration
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=4000

# Vector Store Configuration
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=text-embedding-3-small

# Repository Context Configuration
REPO_CLONE_DIR=./data/repos
MAX_FILE_SIZE_KB=500
MAX_CONTEXT_FILES=15
CODE_SNIPPET_MAX_LINES=50

# Analysis Configuration
MAX_HISTORICAL_ISSUES=10
MAX_RECENT_COMMITS=10
SIMILARITY_THRESHOLD=0.7

# Prompt Configuration
REPO_STRUCTURE_MAX_LINES=100
PROMPT_REPO_STRUCTURE_MAX_CHARS=500
PROMPT_FILE_CONTENT_MAX_CHARS=1000

# Webhook Configuration
WEBHOOK_VERIFY_SSL=true
WEBHOOK_TIMEOUT_SECONDS=30
